# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (Verdanist DB)
DATABASE_URL=postgresql://postgres:password@localhost:5432/verdanist

# MQTT Broker (e.g. Holo Smart / Cloud)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=verdanist-backend
MQTT_USERNAME=
MQTT_PASSWORD=
# Use TLS for production: mqtts://broker.example.com:8883

# API (optional - for dashboard auth)
API_KEY=
