{
  "version": "1.0.0",
  "name": "verdanist-greenhouse",
  "description": "ESP32 Firebase IoT Greenhouse Simulator",
  "author": "Verdanist Team",
  "dependencies": {
    "FirebaseESP32": "^3.9.0",
    "ArduinoJson": "^6.19.0",
    "Time": "^1.6.0"
  },
  "libraries": [
    "FirebaseESP32",
    "ArduinoJson",
    "Time"
  ],
  "sketch": "main.cpp",
  "hardware": {
    "esp32": {
      "board": "esp32dev",
      "flash_size": "4MB",
      "upload_speed": "921600"
    }
  },
  "wokwi": {
    "version": "1.0.0",
    "diagram": {
      "width": 800,
      "height": 600,
      "grid_size": 20
    },
    "simulation": {
      "real_time": true,
      "auto_start": false,
      "serial_monitor": true
    }
  }
}
